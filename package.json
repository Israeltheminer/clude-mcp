{
  "name": "clude-mcp",
  "version": "1.0.0",
  "description": "MCP server for clude-bot persistent memory SDK",
  "main": "dist/index.js",
  "bin": {
    "clude-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "patch-package",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "ingest": "LOG_LEVEL=silent node --require tsx/cjs scripts/ingest-sessions.ts",
    "decay": "LOG_LEVEL=silent node --require tsx/cjs scripts/decay.ts",
    "dream": "LOG_LEVEL=silent node --require tsx/cjs scripts/dream.ts",
    "clear": "node --require tsx/cjs scripts/clear-memory.ts",
    "rescore": "LOG_LEVEL=silent node --require tsx/cjs scripts/rescore-memories.ts",
    "retag": "LOG_LEVEL=silent node --require tsx/cjs scripts/retag-memories.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "adm-zip": "^0.5.16",
    "clude-bot": "^2.7.8",
    "dotenv": "^16.6.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "patch-package": "^8.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "hono": ">=4.12.7"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
